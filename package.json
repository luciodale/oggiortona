{
  "name": "oggi-a-ortona",
  "type": "module",
  "version": "0.1.0",
  "description": "Mangiare e fare a Ortona",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && cp public/.assetsignore dist/.assetsignore",
    "preview": "bun run build && wrangler dev",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:reset:local": "./scripts/db-reset.sh local",
    "db:migrate:local": "wrangler d1 execute oggi-a-ortona-db --file=src/db/migrations/0001_initial.sql --local",
    "db:seed:local": "wrangler d1 execute oggi-a-ortona-db --file=src/db/seed.sql --local",
    "db:studio": "bunx localflare attach",
    "tunnel": "bunx cloudflared tunnel --url http://localhost:4321",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "astro check && tsc --noEmit",
    "lint": "echo 'No linter configured yet'",
    "deploy:cron": "cd workers/cron && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/cloudflare": "12",
    "@astrojs/react": "^4.3.0",
    "@astrojs/sitemap": "^3.5.0",
    "@clerk/astro": "^3.0.7",
    "@clerk/types": "^4.101.20",
    "@floating-ui/react": "^0.27.19",
    "@hookform/resolvers": "^5.2.2",
    "@luciodale/react-searchable-dropdown": "^1.0.3",
    "@nanostores/react": "^1.1.0",
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.7",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "astro": "^5.13.2",
    "drizzle-orm": "^0.45.2",
    "jotai": "^2.19.0",
    "leaflet": "^1.9.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.72.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.8.3",
    "wrangler": "^4.76.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/leaflet": "^1.9.21",
    "vitest": "^3.2.1"
  }
}
