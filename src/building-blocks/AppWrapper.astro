---
import AppHead from "./AppHead.astro";
import BottomNav from "./BottomNav.astro";
import Layout from "./Layout.astro";
import { t } from "../i18n/t";
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  hideNav?: boolean;
  bodyClass?: string;
  layoutClass?: string;
};

const {
  title,
  description,
  hideNav = false,
  bodyClass = "",
  layoutClass = "",
} = Astro.props;

function getThemeColor(cls: string) {
  if (cls.includes("page-mangiare")) return "#fdf2ed";
  if (cls.includes("page-fare")) return "#edf4f8";
  return "#fdfaf6";
}

const themeColor = getThemeColor(bodyClass);

const locale = Astro.locals.locale;
---

<!doctype html>
<html lang={locale}>
  <head>
    <AppHead title={title} description={description} themeColor={themeColor} />
  </head>
  <body class:list={[bodyClass]}>
    <a href="#main-content" class="skip-link">{t("common.skipToContent", locale)}</a>
    <!-- Splash screen (first visit only) -->
    <div id="splash" aria-hidden="true" style="position:fixed;inset:0;z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#fdfaf6;transition:opacity 0.4s ease-out;"></div>
    <script is:inline>
      (function() {
        var s = document.getElementById("splash");
        if (!s) return;
        if (sessionStorage.getItem("splashShown")) {
          s.remove();
          return;
        }
        s.innerHTML = '<img src="/icon.svg" alt="" width="80" height="80" style="border-radius:20px;"><p style="margin-top:16px;font-family:Georgia,Times New Roman,serif;font-size:18px;font-weight:600;color:#2c1810;letter-spacing:1px;">Oggi a Ortona</p>';
        sessionStorage.setItem("splashShown", "1");
        setTimeout(function() {
          s.style.opacity = "0";
          setTimeout(function() { s.remove(); }, 400);
        }, 600);
      })();
    </script>

    <Layout class={layoutClass}>
      <slot />
    </Layout>
    {!hideNav && <BottomNav />}
    <script is:inline>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/sw.js");
      }
    </script>
  </body>
</html>
