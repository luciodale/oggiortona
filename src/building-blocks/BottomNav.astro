---
const currentPath = Astro.url.pathname;

type NavItem = {
  label: string;
  href: string;
  section: string;
};

const items: Array<NavItem> = [
  { label: "Mangiare", href: "/mangiare", section: "mangiare" },
  { label: "Oggi", href: "/", section: "home" },
  { label: "Fare", href: "/fare", section: "fare" },
];

function isActive(item: NavItem) {
  if (item.section === "home") return currentPath === "/" || currentPath === "";
  return currentPath.startsWith(item.href);
}

function getActiveColor(section: string) {
  if (section === "mangiare") return "text-mangiare";
  if (section === "fare") return "text-fare";
  return "text-accent";
}
---

<div class="fixed inset-x-0 bottom-0 z-40 flex justify-center px-5 pb-[max(0.625rem,env(safe-area-inset-bottom))]">
  <nav
    class="nav-glass flex w-full max-w-sm items-center justify-around px-2 py-2"
    aria-label="Navigazione principale"
  >
    {
      items.map((item) => {
        const active = isActive(item);
        return (
          <a
            href={item.href}
            class:list={[
              "flex flex-col items-center gap-0.5 px-5 py-1 text-[10px] font-semibold uppercase tracking-[0.06em] no-underline transition-all",
              active ? getActiveColor(item.section) : "text-muted/50",
            ]}
            aria-current={active ? "page" : undefined}
          >
            <svg class="h-[20px] w-[20px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={active ? "2.2" : "1.5"} stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              {item.section === "mangiare" && (
                <Fragment>
                  <path d="M18 8h1a4 4 0 0 1 0 8h-1" />
                  <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z" />
                  <line x1="6" y1="1" x2="6" y2="4" />
                  <line x1="10" y1="1" x2="10" y2="4" />
                  <line x1="14" y1="1" x2="14" y2="4" />
                </Fragment>
              )}
              {item.section === "home" && (
                <Fragment>
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                  <polyline points="9 22 9 12 15 12 15 22" />
                </Fragment>
              )}
              {item.section === "fare" && (
                <Fragment>
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </Fragment>
              )}
            </svg>
            <span>{item.label}</span>
          </a>
        );
      })
    }
  </nav>
</div>
