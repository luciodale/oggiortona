---
import { CalendarIcon } from "../icons/CalendarIcon";
import { CupIcon } from "../icons/CupIcon";
import { HomeIcon } from "../icons/HomeIcon";
import { ShieldIcon } from "../icons/ShieldIcon";
import { UserIcon } from "../icons/UserIcon";

const currentPath = Astro.url.pathname;
const user = Astro.locals.user;
const isAdmin = Astro.locals.isAdmin;

type NavItem = {
  label: string;
  href: string;
  section: string;
  Icon: typeof CupIcon;
};

const items: Array<NavItem> = [
  { label: "Oggi", href: "/", section: "home", Icon: HomeIcon },
  {
    label: "Mangiare",
    href: "/restaurants",
    section: "mangiare",
    Icon: CupIcon,
  },
  { label: "Eventi", href: "/events", section: "fare", Icon: CalendarIcon },
  {
    label: user ? "Profilo" : "Accedi",
    href: "/profile",
    section: "profilo",
    Icon: UserIcon,
  },
  ...(isAdmin
    ? [{ label: "Admin", href: "/admin", section: "admin", Icon: ShieldIcon }]
    : []),
];

function isActive(item: NavItem) {
  if (item.section === "home") return currentPath === "/" || currentPath === "";
  if (item.section === "profilo")
    return (
      currentPath.startsWith("/profile") ||
      currentPath.startsWith("/add") ||
      currentPath.startsWith("/sign-in")
    );
  if (item.section === "admin") return currentPath.startsWith("/admin");
  return currentPath.startsWith(item.href);
}

function getActiveColor(section: string) {
  if (section === "mangiare") return "text-mangiare";
  if (section === "fare") return "text-fare";
  return "text-accent";
}
---

<div
  class="fixed inset-x-0 bottom-0 z-40 flex justify-center px-5 pb-[max(0.625rem,env(safe-area-inset-bottom))]"
>
  <nav
    class="nav-glass flex w-full max-w-sm items-center justify-around px-1 py-2"
    aria-label="Navigazione principale"
  >
    {
      items.map((item) => {
        const active = isActive(item);
        return (
          <a
            href={item.href}
            class:list={[
              "flex min-h-[44px] min-w-[44px] flex-col items-center justify-center gap-0.5 px-3 py-1.5 text-[10px] font-semibold uppercase tracking-[0.06em] no-underline transition-all",
              active ? getActiveColor(item.section) : "text-muted/50",
            ]}
            aria-current={active ? "page" : undefined}
          >
            <item.Icon
              className="h-[20px] w-[20px]"
              strokeWidth={active ? 2.2 : 1.5}
            />
            <span>{item.label}</span>
          </a>
        );
      })
    }
  </nav>
</div>
