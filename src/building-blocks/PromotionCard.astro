---
import { t } from "../i18n/t";
import type { PromotionRow } from "../types/database";
import { formatDateShort } from "../utils/date";

type Props = { item: PromotionRow };
const { item } = Astro.props;
const locale = Astro.locals.locale;
const isMultiDay = item.dateStart !== item.dateEnd;

type Style = { bg: string; label: string; labelColor: string };
const fallback: Style = {
  bg: "bg-sky-50",
  label: t("promo.news", locale),
  labelColor: "text-sky-700",
};
const styleMap: Record<string, Style> = {
  special: {
    bg: "bg-mangiare-light",
    label: t("promo.dailySpecial", locale),
    labelColor: "text-mangiare",
  },
  deal: {
    bg: "bg-violet-50",
    label: t("promo.deal", locale),
    labelColor: "text-violet-700",
  },
  news: fallback,
};
const style: Style = styleMap[item.type] ?? fallback;
---

<div class:list={["rounded-2xl p-4", style.bg]}>
  <p
    class:list={[
      "text-[10px] font-semibold uppercase tracking-[0.12em]",
      style.labelColor,
    ]}
  >
    {style.label}
  </p>
  <p class="mt-1.5 font-family-display text-base font-medium text-primary">
    {item.title}
  </p>
  {
    item.description && (
      <p class="mt-0.5 text-[12px] text-muted">{item.description}</p>
    )
  }
  <div class="mt-1 flex flex-wrap items-center gap-x-2 text-[11px] text-muted">
    {
      item.price != null && (
        <span class:list={["font-bold", style.labelColor]}>
          {item.price.toFixed(2)}&euro;
        </span>
      )
    }
    {
      item.timeStart && item.timeEnd && (
        <span>
          {item.timeStart} &ndash; {item.timeEnd}
        </span>
      )
    }
    {
      isMultiDay && (
        <span>
          {t("common.untilDate", locale, {
            date: formatDateShort(item.dateEnd, locale),
          })}
        </span>
      )
    }
  </div>
</div>
