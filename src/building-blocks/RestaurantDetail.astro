---
import { restaurantTypeLabels } from "../config/categories";
import { t } from "../i18n/t";
import type { PromotionRow, RestaurantRow } from "../types/database";
import { parseTypes } from "../utils/restaurant";
import {
  formatSchedule,
  getDayLabel,
  getOrderedDays,
  isOpenNow,
  parseOpeningHours,
} from "../utils/time";
import PromotionCard from "./PromotionCard.astro";

type Props = {
  restaurant: RestaurantRow;
  promotions: Array<PromotionRow>;
  backHref: string;
  backLabel: string;
};

const { restaurant, promotions, backHref, backLabel } = Astro.props;
const locale = Astro.locals.locale;

const types = parseTypes(restaurant.type);
const labels = restaurantTypeLabels(locale);
const parsedHours = parseOpeningHours(restaurant.openingHours);
const isOpen = isOpenNow(parsedHours);
const days = getOrderedDays();
---

<a
  href={backHref}
  class="mb-4 inline-flex items-center gap-1 text-xs font-medium text-muted no-underline hover:text-primary"
>
  <svg
    class="h-3.5 w-3.5"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <line x1="19" y1="12" x2="5" y2="12"></line>
    <polyline points="12 19 5 12 12 5"></polyline>
  </svg>
  {backLabel}
</a>

<div class="animate-fade-up">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h1
        class="font-family-display text-2xl font-medium leading-tight text-primary"
      >
        {restaurant.name}
      </h1>
      <div class="mt-1 flex items-center gap-2 text-[11px] text-muted">
        <span class="capitalize"
          >{types.map((tp) => labels[tp] ?? tp).join(" · ")}</span
        >
        <span aria-hidden="true">&middot;</span>
        <span
          aria-label={t("aria.priceRange", locale, {
            range: restaurant.priceRange,
          })}
        >
          {
            [1, 2, 3].map((i) => (
              <span
                aria-hidden="true"
                class:list={[
                  i <= restaurant.priceRange ? "text-primary" : "text-border",
                ]}
              >
                &euro;
              </span>
            ))
          }
        </span>
      </div>
    </div>
    <span
      class:list={[
        "mt-1 flex items-center gap-1 rounded-full px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wide",
        isOpen ? "bg-success/10 text-success" : "bg-danger/10 text-danger",
      ]}
    >
      <span
        class:list={[
          "h-1.5 w-1.5 rounded-full",
          isOpen ? "bg-success" : "bg-danger",
        ]}
        aria-hidden="true"></span>
      {isOpen ? t("common.open", locale) : t("common.closed", locale)}
    </span>
  </div>

  {
    restaurant.description && (
      <p class="mt-3 text-[13px] leading-relaxed text-muted">
        {restaurant.description}
      </p>
    )
  }

  <div class="mt-5 flex gap-2">
    {
      restaurant.phone && (
        <a
          href={`https://wa.me/${restaurant.phone.replace(/[\s\-+()]/g, "")}?text=${encodeURIComponent(t("aria.whatsappMessage", locale))}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t("aria.whatsappTo", locale, { name: restaurant.name })}
          class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-[#25D366] py-3 text-[13px] font-semibold text-white no-underline transition-all hover:bg-[#1FAD55] active:scale-[0.98]"
        >
          {t("common.whatsapp", locale)}
        </a>
      )
    }
    <a
      href={restaurant.latitude != null && restaurant.longitude != null
        ? `https://www.google.com/maps/search/?api=1&query=${restaurant.latitude},${restaurant.longitude}`
        : `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(restaurant.address)}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={t("aria.directionsFor", locale, { name: restaurant.name })}
      class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-primary py-3 text-[13px] font-semibold text-white no-underline transition-all hover:bg-primary/90 active:scale-[0.98]"
      >{t("common.directions", locale)}</a
    >
    {
      restaurant.phone && (
        <a
          href={`tel:${restaurant.phone}`}
          aria-label={t("aria.callName", locale, { name: restaurant.name })}
          class="flex flex-1 items-center justify-center gap-2 rounded-xl border border-border bg-white py-3 text-[13px] font-semibold text-primary no-underline transition-all hover:bg-surface-alt active:scale-[0.98]"
        >
          {t("common.call", locale)}
        </a>
      )
    }
    {
      restaurant.menuUrl && (
        <a
          href={restaurant.menuUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t("aria.menuOf", locale, { name: restaurant.name })}
          class="flex flex-1 items-center justify-center gap-2 rounded-xl border border-border bg-white py-3 text-[13px] font-semibold text-primary no-underline transition-all hover:bg-surface-alt active:scale-[0.98]"
        >
          {t("common.menu", locale)}
        </a>
      )
    }
  </div>

  <div class="mt-5 flex flex-col gap-3">
    {promotions.map((p) => <PromotionCard item={p} />)}
  </div>

  <div class="mt-8">
    <h2
      class="mb-3 text-[10px] font-semibold uppercase tracking-[0.15em] text-muted"
    >
      {t("common.hours", locale)}
    </h2>
    <div class="rounded-2xl bg-white shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
      {
        days.map((day, i) => {
          const schedule = parsedHours[day];
          return (
            <div
              class:list={[
                "flex items-center justify-between px-4 py-3",
                i < days.length - 1 && "border-b border-border-light",
              ]}
            >
              <span class="text-[13px] font-medium text-primary">
                {getDayLabel(day, locale)}
              </span>
              <span
                class:list={[
                  "text-[13px]",
                  schedule ? "text-muted" : "text-danger/60",
                ]}
              >
                {formatSchedule(schedule, locale)}
              </span>
            </div>
          );
        })
      }
    </div>
  </div>

  <div class="mt-8 pb-4">
    <h2
      class="mb-2 text-[10px] font-semibold uppercase tracking-[0.15em] text-muted"
    >
      {t("common.address", locale)}
    </h2>
    <p class="text-[13px] text-primary">{restaurant.address}</p>
  </div>
</div>
