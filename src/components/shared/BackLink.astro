---
type Props = {
  href: string;
  label?: string;
};

const { href, label = "Torna indietro" } = Astro.props;
---

<a
  href={href}
  class="mb-4 inline-flex items-center gap-1 text-sm text-muted no-underline transition-colors hover:text-primary"
>
  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="19" y1="12" x2="5" y2="12" />
    <polyline points="12 19 5 12 12 5" />
  </svg>
  {label}
</a>
