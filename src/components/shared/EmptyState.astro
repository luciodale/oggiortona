---
type Props = {
  message?: string;
};

const { message = "Nessun risultato" } = Astro.props;
---

<div class="flex flex-col items-center justify-center py-16 text-center" role="status">
  <svg class="mb-3 h-12 w-12 text-border" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="10" />
    <line x1="8" y1="15" x2="16" y2="15" />
    <line x1="9" y1="9" x2="9.01" y2="9" />
    <line x1="15" y1="9" x2="15.01" y2="9" />
  </svg>
  <p class="text-sm text-muted">{message}</p>
</div>
