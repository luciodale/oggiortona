---
import AppHead from "../building-blocks/AppHead.astro";
import { siteConfig } from "../config/site";
import { t } from "../i18n/t";
import { SpaApp } from "../App";
import "../styles/global.css";

const locale = Astro.locals.locale;
const user = Astro.locals.user;
const isAdmin = Astro.locals.isAdmin;

function getThemeColor() {
  return "#fdfaf6"; // overridden by theme init script for dark mode
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <AppHead
      title={siteConfig.title}
      description={t("common.siteName", locale)}
      themeColor={getThemeColor()}
    />
  </head>
  <body class="bg-surface">
    <a href="#main-content" class="skip-link"
      >{t("common.skipToContent", locale)}</a
    >

    <div
      id="app-loader"
      aria-hidden="true"
      style="position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:var(--color-surface);transition:opacity 0.4s ease-out;"
    >
      <img
        src="/icon.svg"
        alt=""
        width="64"
        height="64"
        style="border-radius:16px;animation:logo-bounce 0.8s ease-in-out infinite;"
      />
    </div>
    <style>
      @keyframes logo-bounce {
        0%,
        100% {
          transform: translateY(0) scale(1);
        }
        50% {
          transform: translateY(-10px) scale(1.05);
        }
      }
    </style>

    <SpaApp
      client:only="react"
      locale={locale}
      user={user
        ? {
            id: user.id,
            name: user.name,
            email: user.email,
            avatarUrl: user.avatarUrl,
          }
        : null}
      isAdmin={isAdmin}
    />

    <div
      id="app-error"
      hidden
      style="position:fixed;inset:0;z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--color-surface);padding:1.5rem;text-align:center;font-family:var(--font-family);"
    >
      <svg width="160" height="96" viewBox="0 0 200 120" fill="var(--color-accent)" aria-hidden="true" style="margin-bottom:1.5rem;">
        <g opacity="0.12" transform="translate(1.5, 1.5)">
          <g transform="rotate(28 100 45)">
            <path d="M62 10 L138 10 C148 28, 130 50, 103 55 L97 55 C70 50, 52 28, 62 10Z" />
            <rect x="97" y="55" width="6" height="23" rx="2" />
            <ellipse cx="100" cy="80" rx="24" ry="5" />
          </g>
          <ellipse cx="140" cy="108" rx="44" ry="6" />
          <ellipse cx="128" cy="112" rx="16" ry="3" />
        </g>
        <g transform="rotate(28 100 45)">
          <path d="M62 10 L138 10 C148 28, 130 50, 103 55 L97 55 C70 50, 52 28, 62 10Z" opacity="0.4" />
          <path d="M72 24 L128 24 C138 40, 128 50, 103 55 L97 55 C72 50, 62 40, 72 24Z" opacity="0.25" />
          <rect x="97" y="55" width="6" height="23" rx="2" opacity="0.5" />
          <ellipse cx="100" cy="80" rx="24" ry="5" opacity="0.35" />
        </g>
        <ellipse cx="140" cy="108" rx="44" ry="6" opacity="0.22" />
        <ellipse cx="128" cy="112" rx="16" ry="3" opacity="0.3" />
        <circle cx="170" cy="100" r="2" opacity="0.35" />
        <circle cx="96" cy="104" r="1.5" opacity="0.3" />
      </svg>
      <h1 id="app-error-title" style="font-family:'Playfair Display',Georgia,serif;font-size:1.5rem;font-weight:500;letter-spacing:-0.025em;color:var(--color-primary);margin:0;"></h1>
      <p id="app-error-desc" style="margin-top:0.5rem;max-width:22rem;font-size:0.875rem;color:var(--color-muted);"></p>
      <div style="margin-top:2rem;display:flex;flex-wrap:wrap;gap:0.75rem;justify-content:center;">
        <button
          onclick="window.location.reload()"
          style="padding:0.75rem 1.5rem;border:none;border-radius:0.75rem;background:var(--color-accent);color:white;font-size:0.875rem;font-weight:600;cursor:pointer;"
          id="app-error-reload-btn"
        ></button>
        <button
          onclick="window.location.href='/'"
          style="padding:0.75rem 1.5rem;border:1px solid var(--color-border);border-radius:0.75rem;background:transparent;color:var(--color-primary);font-size:0.875rem;font-weight:600;cursor:pointer;"
          id="app-error-btn"
        ></button>
      </div>
    </div>

    <script is:inline>
      (function() {
        var isIt = document.documentElement.lang === "it";
        document.getElementById("app-error-title").textContent = isIt ? "Ops, qualcosa è caduto" : "Oops, a little spill";
        document.getElementById("app-error-desc").textContent = isIt ? "Un piccolo imprevisto in sala. Ricarica la pagina o torna alla home." : "A small mishap in the dining room. Reload the page or head back home.";
        document.getElementById("app-error-reload-btn").textContent = isIt ? "Ricarica" : "Reload";
        document.getElementById("app-error-btn").textContent = isIt ? "Torna alla home" : "Back to home";

        var shown = false;
        function showError() {
          if (shown) return;
          shown = true;
          var loader = document.getElementById("app-loader");
          if (loader) loader.style.display = "none";
          document.getElementById("app-error").hidden = false;
        }

        // Catch resource load failures (script/link/img)
        window.addEventListener("error", function(e) {
          if (e.target !== window && e.target.tagName) showError();
        }, true);

        // Catch any unhandled promise rejection
        window.addEventListener("unhandledrejection", function() {
          showError();
        });

        // Fallback: if app-loader is still visible after 15s, something failed silently
        setTimeout(function() {
          var loader = document.getElementById("app-loader");
          if (loader && loader.style.opacity !== "0") showError();
        }, 15000);
      })();
    </script>

    <script is:inline>
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/sw.js");
      }
    </script>
  </body>
</html>
