---
import AppWrapper from "../../building-blocks/AppWrapper.astro";
import AdminApp from "../../components/admin/AdminApp";

export const prerender = false;

const user = Astro.locals.user;
const isAdmin = Astro.locals.isAdmin;

if (!user) {
  return Astro.redirect(`/sign-in?redirect_url=${encodeURIComponent(Astro.url.pathname)}`);
}

if (!isAdmin) {
  return Astro.redirect("/");
}
---

<AppWrapper title="Admin" description="Pannello di amministrazione">
  <AdminApp client:only="react" />
</AppWrapper>
