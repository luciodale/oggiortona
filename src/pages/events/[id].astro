---
import { and as dbAnd, eq } from "drizzle-orm";
import AppWrapper from "../../building-blocks/AppWrapper.astro";
import {
  eventCategoryColors,
  eventCategoryLabels,
} from "../../config/categories";
import { events } from "../../db/schema";
import { t } from "../../i18n/t";
import { formatDateLong } from "../../utils/date";

const locale = Astro.locals.locale;
const db = Astro.locals.db;
const eventId = Number(Astro.params.id);

const [event] = await db
  .select()
  .from(events)
  .where(dbAnd(eq(events.id, eventId), eq(events.active, 1)))
  .limit(1);

if (!event) {
  return Astro.redirect("/events");
}

const categories = event.category.split(",").map((c: string) => c.trim());
const catLabels = eventCategoryLabels(locale);
---

<AppWrapper
  title={event.title}
  description={event.description ?? `${event.title} a Ortona`}
  bodyClass="page-fare"
>
  <a
    href="/events"
    class="mb-4 inline-flex items-center gap-1 text-xs font-medium text-muted no-underline hover:text-primary"
  >
    <svg
      class="h-3.5 w-3.5"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="19" y1="12" x2="5" y2="12"></line>
      <polyline points="12 19 5 12 12 5"></polyline>
    </svg>
    {t("events.allEvents", locale)}
  </a>

  <div class="animate-fade-up">
    <div class="flex flex-wrap gap-1">
      {
        categories.map((cat: string) => (
          <span
            class:list={[
              "inline-block rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide",
              eventCategoryColors[cat] ?? "bg-stone-100 text-stone-600",
            ]}
          >
            {catLabels[cat] ?? cat}
          </span>
        ))
      }
    </div>

    <h1
      class="mt-3 font-family-display text-2xl font-medium leading-tight text-primary"
    >
      {event.title}
    </h1>

    <div
      class="mt-5 space-y-3 rounded-2xl bg-white p-4 shadow-[0_1px_3px_rgba(0,0,0,0.04)]"
    >
      <div class="flex items-center gap-3 text-[13px] text-primary">
        <div
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-fare-light"
        >
          <svg
            class="h-4 w-4 text-fare"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
        </div>
        <div>
          <span class="capitalize"
            >{formatDateLong(event.dateStart, locale)}</span
          >
          {
            event.dateEnd && (
              <span>
                {" "}
                &ndash;{" "}
                <span class="capitalize">
                  {formatDateLong(event.dateEnd, locale)}
                </span>
              </span>
            )
          }
        </div>
      </div>
      {
        event.timeStart && (
          <div class="flex items-center gap-3 text-[13px] text-primary">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-fare-light">
              <svg
                class="h-4 w-4 text-fare"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
            </div>
            <span>
              {event.timeStart}
              {event.timeEnd && ` \u2013 ${event.timeEnd}`}
            </span>
          </div>
        )
      }
      {
        event.price != null && (
          <div class="flex items-center gap-3 text-[13px] text-primary">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-fare-light">
              <svg
                class="h-4 w-4 text-fare"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z" />
                <line x1="7" y1="7" x2="7.01" y2="7" />
              </svg>
            </div>
            <span class="font-medium">{event.price.toFixed(2)}&euro;</span>
          </div>
        )
      }
    </div>

    <div class="mt-5 flex gap-2">
      {
        event.phone && (
          <a
            href={`https://wa.me/${event.phone.replace(/[\s\-+()]/g, "")}?text=${encodeURIComponent(t("aria.whatsappMessage", locale))}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t("aria.whatsappFor", locale, { name: event.title })}
            class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-[#25D366] py-3 text-[13px] font-semibold text-white no-underline transition-all hover:bg-[#1FAD55] active:scale-[0.98]"
          >
            {t("common.whatsapp", locale)}
          </a>
        )
      }
      <a
        href={event.latitude != null && event.longitude != null
          ? `https://www.google.com/maps/search/?api=1&query=${event.latitude},${event.longitude}`
          : `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(event.address)}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t("aria.directionsFor", locale, { name: event.title })}
        class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-primary py-3 text-[13px] font-semibold text-white no-underline transition-all hover:bg-primary/90 active:scale-[0.98]"
        >{t("common.directions", locale)}</a
      >
      {
        event.phone && (
          <a
            href={`tel:${event.phone}`}
            aria-label={t("aria.callFor", locale, { name: event.title })}
            class="flex flex-1 items-center justify-center gap-2 rounded-xl border border-border bg-white py-3 text-[13px] font-semibold text-primary no-underline transition-all hover:bg-surface-alt active:scale-[0.98]"
          >
            {t("common.call", locale)}
          </a>
        )
      }
    </div>

    {
      event.description && (
        <div class="mt-6">
          <h2 class="mb-2 text-[10px] font-semibold uppercase tracking-[0.15em] text-muted">
            {t("common.details", locale)}
          </h2>
          <p class="text-[13px] leading-relaxed text-muted">
            {event.description}
          </p>
        </div>
      )
    }

    <div class="mt-8 pb-4">
      <h2
        class="mb-2 text-[10px] font-semibold uppercase tracking-[0.15em] text-muted"
      >
        {t("common.address", locale)}
      </h2>
      <p class="text-[13px] text-primary">{event.address}</p>
    </div>
  </div>
</AppWrapper>
