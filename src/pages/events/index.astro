---
import AppWrapper from "../../building-blocks/AppWrapper.astro";
import ZipperScroll from "../../components/shared/ZipperScroll.astro";
import { EventsView } from "../../components/events/EventsView";
import { events } from "../../db/schema";
import { gte, asc, eq, and as dbAnd, or } from "drizzle-orm";

const db = Astro.locals.db;
const today = new Date().toISOString().split("T")[0]!;

const allEvents = await db
  .select()
  .from(events)
  .where(dbAnd(
    eq(events.active, 1),
    or(gte(events.dateStart, today), gte(events.dateEnd, today)),
  ))
  .orderBy(asc(events.dateStart), asc(events.timeStart));
---

<AppWrapper
  title="Fare"
  description="Eventi, sagre, concerti e attivita a Ortona."
  bodyClass="page-fare"
>
  <div class="mb-6 animate-fade-up flex items-start justify-between">
    <div>
      <h1 class="font-[family-name:var(--font-family-display)] text-3xl font-medium tracking-tight text-primary">
        Fare
      </h1>
    </div>
    <button
      id="refresh-btn"
      type="button"
      aria-label="Aggiorna"
      class="mt-1 flex h-9 w-9 items-center justify-center rounded-full border border-border-light bg-surface text-muted transition-all duration-300 hover:border-fare-muted hover:text-fare active:scale-90"
    >
      <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="23 4 23 10 17 10" />
        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
      </svg>
    </button>
  </div>

  <script>
    const btn = document.getElementById("refresh-btn");
    btn?.addEventListener("click", () => {
      btn.querySelector("svg")?.classList.add("animate-spin");
      window.location.reload();
    });
  </script>

  <EventsView client:load events={allEvents} />
  <ZipperScroll />
</AppWrapper>
