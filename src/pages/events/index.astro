---
import AppWrapper from "../../building-blocks/AppWrapper.astro";
import ZipperScroll from "../../components/shared/ZipperScroll.astro";
import { EventsView } from "../../components/events/EventsView";
import { events } from "../../db/schema";
import { gte, asc, eq, and as dbAnd, or } from "drizzle-orm";
import { t } from "../../i18n/t";

const locale = Astro.locals.locale;
const db = Astro.locals.db;
const today = new Date().toISOString().split("T")[0]!;

const allEvents = await db
  .select()
  .from(events)
  .where(
    dbAnd(
      eq(events.active, 1),
      eq(events.deleted, 0),
      or(gte(events.dateStart, today), gte(events.dateEnd, today)),
    ),
  )
  .orderBy(asc(events.dateStart), asc(events.timeStart));
---

<AppWrapper
  title={t("events.pageTitle", locale)}
  description={t("events.pageDesc", locale)}
  bodyClass="page-fare"
>
  <div class="mb-6 animate-fade-up flex items-start justify-between">
    <div>
      <h1
        class="font-family-display text-3xl font-medium tracking-tight text-primary"
      >
        {t("events.pageTitle", locale)}
      </h1>
    </div>
    <button
      id="refresh-btn"
      type="button"
      aria-label={t("common.refresh", locale)}
      class="mt-1 flex h-9 w-9 items-center justify-center rounded-full border border-border-light bg-surface text-muted transition-all duration-300 hover:border-fare-muted hover:text-fare active:scale-90"
    >
      <svg
        class="h-[18px] w-[18px]"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="23 4 23 10 17 10"></polyline>
        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
      </svg>
    </button>
  </div>

  <script>
    import { initRefreshButton } from "../../utils/refresh";
    initRefreshButton();
  </script>

  <EventsView client:load events={allEvents} locale={locale} />
  <ZipperScroll />
</AppWrapper>
