---
import AppWrapper from "../../building-blocks/AppWrapper.astro";
import type { D1Database } from "@cloudflare/workers-types";
import type { EventRow } from "../../types/database";
import { eventCategoryLabels, eventCategoryColors } from "../../config/categories";
import { formatDateItalian } from "../../utils/date";

const db = Astro.locals.runtime.env.DB as D1Database;
const { id } = Astro.params;

const event = await db
  .prepare("SELECT * FROM events WHERE id = ?")
  .bind(id)
  .first<EventRow>();

if (!event) {
  return Astro.redirect("/fare");
}

const colorClass = eventCategoryColors[event.category];
---

<AppWrapper
  title={event.title}
  description={event.description ?? `${event.title} a Ortona`}
  bodyClass="page-fare"
>
  <a
    href="/fare"
    class="mb-4 inline-flex items-center gap-1 text-xs font-medium text-muted no-underline hover:text-primary"
  >
    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="19" y1="12" x2="5" y2="12" />
      <polyline points="12 19 5 12 12 5" />
    </svg>
    Tutti gli eventi
  </a>

  <div class="animate-fade-up">
    <span class:list={["inline-block rounded-full px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide", colorClass]}>
      {eventCategoryLabels[event.category]}
    </span>

    <h1 class="mt-3 font-[family-name:var(--font-family-display)] text-2xl font-medium leading-tight text-primary">
      {event.title}
    </h1>

    <!-- Details card -->
    <div class="mt-5 space-y-3 rounded-2xl bg-white p-4 shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
      <div class="flex items-center gap-3 text-[13px] text-primary">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-fare-light">
          <svg class="h-4 w-4 text-fare" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
        </div>
        <div>
          <span class="capitalize">{formatDateItalian(event.date_start)}</span>
          {event.date_end && (
            <span> &ndash; <span class="capitalize">{formatDateItalian(event.date_end)}</span></span>
          )}
        </div>
      </div>
      {event.time_start && (
        <div class="flex items-center gap-3 text-[13px] text-primary">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-fare-light">
            <svg class="h-4 w-4 text-fare" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
          </div>
          <span>{event.time_start}{event.time_end && ` \u2013 ${event.time_end}`}</span>
        </div>
      )}
      <div class="flex items-center gap-3 text-[13px] text-primary">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-fare-light">
          <svg class="h-4 w-4 text-fare" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
        </div>
        <span>{event.location}</span>
      </div>
    </div>

    <!-- Description -->
    {event.description && (
      <div class="mt-6">
        <h2 class="mb-2 text-[10px] font-semibold uppercase tracking-[0.15em] text-muted">
          Dettagli
        </h2>
        <p class="text-[13px] leading-relaxed text-muted">{event.description}</p>
      </div>
    )}
  </div>
</AppWrapper>
