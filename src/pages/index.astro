---
import AppWrapper from "../building-blocks/AppWrapper.astro";
import { NotificationPrompt } from "../components/shared/NotificationPrompt";
import { PwaInstallPrompt } from "../components/shared/PwaInstallPrompt";
import { siteConfig } from "../config/site";
import { t } from "../i18n/t";
import { CalendarIcon } from "../icons/CalendarIcon";
import { ChevronRightIcon } from "../icons/ChevronRightIcon";
import { ClockIcon } from "../icons/ClockIcon";
import { CupIcon } from "../icons/CupIcon";
import { StarIcon } from "../icons/StarIcon";
import { TagIcon } from "../icons/TagIcon";
import { DAY_NAMES, fetchHomePageData, MONTH_NAMES } from "../utils/homeData";

const locale = Astro.locals.locale;
const {
  restaurantCount,
  specials,
  deals,
  newsCount,
  todayEvents,
  upcomingEvents,
} = await fetchHomePageData(Astro.locals.db);
const d = new Date();
const user = Astro.locals.user;
---

<AppWrapper
  title={siteConfig.title}
  description={t("common.siteName", locale)}
  bodyClass="bg-surface"
>
  <div class="flex flex-col py-6">
    <!-- Hero -->
    <div class="animate-fade-up">
      <div class="flex items-end justify-between gap-4">
        <div class="flex items-center gap-3">
          <img
            src="/icon.svg"
            alt="Oggi a Ortona"
            width="52"
            height="52"
            class="shrink-0 rounded-xl"
          />
          <h1
            class="font-family-display text-[2.25rem] font-medium leading-[1.1] tracking-tight text-primary"
          >
            {t("home.whatHappens", locale)}<br /><em class="text-accent"
              >{t("home.today", locale)}</em
            >
          </h1>
        </div>
        <div class="shrink-0 rounded-2xl bg-surface-warm px-4 py-3 text-right">
          <p
            class="font-family-display text-[2rem] font-semibold leading-none text-primary"
          >
            {d.getDate()}
          </p>
          <p
            class="mt-1 text-[11px] font-semibold uppercase tracking-[0.1em] text-muted"
          >
            {MONTH_NAMES[locale][d.getMonth()]}
          </p>
          <p class="text-[10px] capitalize text-muted/60">
            {DAY_NAMES[locale][d.getDay()]}
          </p>
        </div>
      </div>
    </div>

    <!-- Two section entries -->
    <nav
      class="flex flex-col gap-4 pt-10 stagger-children"
      aria-label={t("home.mainSections", locale)}
    >
      <!-- Mangiare -->
      <a
        href="/restaurants"
        class="group relative overflow-hidden rounded-2xl bg-mangiare-light p-5 no-underline transition-all active:scale-[0.98]"
      >
        <div
          class="absolute right-4 top-4 font-family-display text-[4rem] font-bold leading-none text-mangiare/[0.06]"
          aria-hidden="true"
        >
          M
        </div>
        <span
          class="text-[10px] font-semibold uppercase tracking-[0.15em] text-mangiare/60"
        >
          {t("home.whereToEat", locale)}
        </span>
        <h2 class="mt-1 font-family-display text-2xl font-medium text-primary">
          {t("nav.restaurants", locale)}
        </h2>
        <p class="mt-1.5 text-sm text-muted">
          {t("home.venuesInOrtona", locale, { count: restaurantCount })}
        </p>

        {
          (specials > 0 || deals > 0 || newsCount > 0) && (
            <div class="mt-4 flex flex-wrap gap-2">
              {specials > 0 && (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-mangiare/10 px-2.5 py-1 text-xs font-medium text-mangiare">
                  <StarIcon className="h-3 w-3" strokeWidth={2.5} />
                  {specials === 1
                    ? t("home.specialOne", locale, { count: specials })
                    : t("home.specialMany", locale, { count: specials })}
                </span>
              )}
              {deals > 0 && (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-mangiare/10 px-2.5 py-1 text-xs font-medium text-mangiare">
                  <TagIcon className="h-3 w-3" strokeWidth={2.5} />
                  {deals === 1
                    ? t("home.dealOne", locale, { count: deals })
                    : t("home.dealMany", locale, { count: deals })}
                </span>
              )}
              {newsCount > 0 && (
                <span class="inline-flex items-center gap-1.5 rounded-full bg-sky-500/10 px-2.5 py-1 text-xs font-medium text-sky-600">
                  <StarIcon className="h-3 w-3" strokeWidth={2.5} />
                  {t("home.newsCount", locale, { count: newsCount })}
                </span>
              )}
            </div>
          )
        }

        <div
          class="mt-3 flex items-center gap-1 text-xs font-medium text-mangiare"
        >
          {t("common.explore", locale)}
          <ChevronRightIcon
            className="h-3 w-3 transition-transform group-hover:translate-x-1"
            strokeWidth={2.5}
          />
        </div>
      </a>

      <!-- Events -->
      <a
        href="/events"
        class="group relative overflow-hidden rounded-2xl bg-fare-light p-5 no-underline transition-all active:scale-[0.98]"
      >
        <div
          class="absolute right-4 top-4 font-family-display text-[4rem] font-bold leading-none text-fare/[0.06]"
          aria-hidden="true"
        >
          F
        </div>
        <span
          class="text-[10px] font-semibold uppercase tracking-[0.15em] text-fare/60"
        >
          {t("home.whatToDo", locale)}
        </span>
        <h2 class="mt-1 font-family-display text-2xl font-medium text-primary">
          {t("nav.events", locale)}
        </h2>

        {
          todayEvents > 0 ? (
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-fare/10 px-2.5 py-1 text-xs font-medium text-fare">
                <ClockIcon className="h-3 w-3" strokeWidth={2.5} />
                {todayEvents === 1
                  ? t("home.eventTodayOne", locale, { count: todayEvents })
                  : t("home.eventTodayMany", locale, { count: todayEvents })}
              </span>
            </div>
          ) : (
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-fare/10 px-2.5 py-1 text-xs font-medium text-fare">
                <CalendarIcon className="h-3 w-3" strokeWidth={2.5} />
                {upcomingEvents > 0
                  ? upcomingEvents === 1
                    ? t("home.eventUpcomingOne", locale, {
                        count: upcomingEvents,
                      })
                    : t("home.eventUpcomingMany", locale, {
                        count: upcomingEvents,
                      })
                  : t("home.discoverEvents", locale)}
              </span>
            </div>
          )
        }

        <div class="mt-3 flex items-center gap-1 text-xs font-medium text-fare">
          {t("common.discover", locale)}
          <ChevronRightIcon
            className="h-3 w-3 transition-transform group-hover:translate-x-1"
            strokeWidth={2.5}
          />
        </div>
      </a>

      <!-- Add entry / Login -->
      {
        user ? (
          <div class="rounded-2xl border-2 border-dashed border-border bg-white p-5">
            <p class="text-[10px] font-semibold uppercase tracking-[0.15em] text-muted">
              {t("home.haveVenueOrEvent", locale)}
            </p>
            <p class="mt-1 font-family-display text-lg font-medium text-primary">
              {t("home.addToOrtona", locale)}
            </p>
            <div class="mt-5 flex gap-3">
              <a
                href="/profile/add/restaurant"
                class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-mangiare py-3 text-[13px] font-semibold text-white no-underline transition-all hover:bg-mangiare/90 active:scale-[0.98]"
              >
                <CupIcon className="h-4 w-4" />
                {t("home.venue", locale)}
              </a>
              <a
                href="/add/event"
                class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-fare py-3 text-[13px] font-semibold text-white no-underline transition-all hover:bg-fare/90 active:scale-[0.98]"
              >
                <CalendarIcon className="h-4 w-4" />
                {t("home.event", locale)}
              </a>
            </div>
          </div>
        ) : (
          <a
            href="/sign-in?redirect_url=/"
            class="flex items-center justify-center gap-2 rounded-2xl border-2 border-dashed border-border bg-white p-5 no-underline transition-all active:scale-[0.98]"
          >
            <p class="text-center">
              <span class="block text-[10px] font-semibold uppercase tracking-[0.15em] text-muted">
                {t("home.haveVenueOrEvent", locale)}
              </span>
              <span class="mt-1 block font-family-display text-lg font-medium text-accent">
                {t("home.signInToPublish", locale)}
              </span>
            </p>
          </a>
        )
      }
    </nav>

    <NotificationPrompt client:idle locale={locale} />
    <PwaInstallPrompt client:idle locale={locale} />
  </div>
</AppWrapper>
