---
import AppWrapper from "../../building-blocks/AppWrapper.astro";
import type { D1Database } from "@cloudflare/workers-types";
import type { RestaurantRow, DailySpecialRow } from "../../types/database";
import { isOpenNow, parseOpeningHours, formatSchedule, getDayLabel, getOrderedDays } from "../../utils/time";
import { getTodayISO } from "../../utils/date";
import { restaurantTypeLabels } from "../../config/categories";
import { parseTypes } from "../../utils/restaurant";

const db = Astro.locals.runtime.env.DB as D1Database;
const { id } = Astro.params;

const restaurant = await db
  .prepare("SELECT * FROM restaurants WHERE id = ? AND active = 1")
  .bind(id)
  .first<RestaurantRow>();

if (!restaurant) {
  return Astro.redirect("/mangiare");
}

const today = getTodayISO();
const special = await db
  .prepare("SELECT * FROM daily_specials WHERE restaurant_id = ? AND date = ?")
  .bind(id, today)
  .first<DailySpecialRow>();

const types = parseTypes(restaurant.type);

const parsedHours = parseOpeningHours(restaurant.opening_hours);
const isOpen = isOpenNow(parsedHours);
const days = getOrderedDays();
---

<AppWrapper
  title={restaurant.name}
  description={restaurant.description ?? `${restaurant.name} a Ortona`}
  bodyClass="page-mangiare"
>
  <!-- Back: uses history.back() to preserve map view state + query params -->
  <button
    type="button"
    onclick="history.back()"
    class="mb-4 inline-flex cursor-pointer items-center gap-1 border-none bg-transparent p-0 text-xs font-medium text-muted hover:text-primary"
  >
    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="19" y1="12" x2="5" y2="12" />
      <polyline points="12 19 5 12 12 5" />
    </svg>
    Tutti i locali
  </button>

  <div class="animate-fade-up">
    <!-- Header -->
    <div class="flex items-start justify-between gap-3">
      <div>
        <h1 class="font-[family-name:var(--font-family-display)] text-2xl font-medium leading-tight text-primary">
          {restaurant.name}
        </h1>
        <div class="mt-1 flex items-center gap-2 text-[11px] text-muted">
          <span class="capitalize">{types.map((t) => restaurantTypeLabels[t] ?? t).join(" · ")}</span>
          <span aria-hidden="true">&middot;</span>
          <span>
            {[1, 2, 3].map((i) => (
              <span class:list={[i <= restaurant.price_range ? "text-primary" : "text-border"]}>
                &euro;
              </span>
            ))}
          </span>
        </div>
      </div>
      <span
        class:list={[
          "mt-1 flex items-center gap-1 rounded-full px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wide",
          isOpen ? "bg-success/10 text-success" : "bg-danger/10 text-danger",
        ]}
      >
        <span
          class:list={["h-1.5 w-1.5 rounded-full", isOpen ? "bg-success" : "bg-danger"]}
          aria-hidden="true"
        />
        {isOpen ? "Aperto" : "Chiuso"}
      </span>
    </div>

    {restaurant.description && (
      <p class="mt-3 text-[13px] leading-relaxed text-muted">{restaurant.description}</p>
    )}

    <!-- Action buttons -->
    <div class="mt-5 flex gap-2">
      {restaurant.phone && (
        <a
          href={`https://wa.me/${restaurant.phone.replace(/[\s\-+()]/g, "")}?text=${encodeURIComponent("Ciao, vi ho trovato su Oggi a Ortona!")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-[#25D366] py-3 text-[13px] font-semibold text-white no-underline transition-all hover:bg-[#1FAD55] active:scale-[0.98]"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
          </svg>
          WhatsApp
        </a>
      )}
      {restaurant.google_maps_url && (
        <a
          href={restaurant.google_maps_url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-primary py-3 text-[13px] font-semibold text-white no-underline transition-all hover:bg-primary/90 active:scale-[0.98]"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          Indicazioni
        </a>
      )}
      {restaurant.phone && (
        <a
          href={`tel:${restaurant.phone}`}
          class="flex flex-1 items-center justify-center gap-2 rounded-xl border border-border bg-white py-3 text-[13px] font-semibold text-primary no-underline transition-all hover:bg-surface-alt active:scale-[0.98]"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          Chiama
        </a>
      )}
    </div>

    <!-- Daily special -->
    {special && (
      <div class="mt-6 rounded-2xl bg-mangiare-light p-4">
        <p class="text-[10px] font-semibold uppercase tracking-[0.12em] text-mangiare">
          Piatto del giorno
        </p>
        <p class="mt-1.5 font-[family-name:var(--font-family-display)] text-base text-primary">
          {special.description}
        </p>
        {special.price != null && (
          <p class="mt-1 text-lg font-bold text-mangiare">
            {special.price.toFixed(2)}&euro;
          </p>
        )}
      </div>
    )}

    <!-- Opening hours -->
    <div class="mt-8">
      <h2 class="mb-3 text-[10px] font-semibold uppercase tracking-[0.15em] text-muted">
        Orari
      </h2>
      <div class="rounded-2xl bg-white shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
        {days.map((day, i) => {
          const schedule = parsedHours[day];
          return (
            <div class:list={[
              "flex items-center justify-between px-4 py-3",
              i < days.length - 1 && "border-b border-border-light",
            ]}>
              <span class="text-[13px] font-medium text-primary">
                {getDayLabel(day)}
              </span>
              <span class:list={[
                "text-[13px]",
                schedule ? "text-muted" : "text-danger/60",
              ]}>
                {formatSchedule(schedule)}
              </span>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Address -->
    <div class="mt-8 pb-4">
      <h2 class="mb-2 text-[10px] font-semibold uppercase tracking-[0.15em] text-muted">
        Indirizzo
      </h2>
      <p class="text-[13px] text-primary">{restaurant.address}</p>
    </div>
  </div>
</AppWrapper>
