---
import AppWrapper from "../../building-blocks/AppWrapper.astro";
import ZipperScroll from "../../components/shared/ZipperScroll.astro";
import { RestaurantsView } from "../../components/restaurants/RestaurantsView";
import { restaurants, promotions } from "../../db/schema";
import { eq, and as dbAnd, lte, gte } from "drizzle-orm";
import { getTodayISO } from "../../utils/date";
import { groupPromotionsByRestaurant, enrichRestaurant } from "../../utils/enrichRestaurant";
import { t } from "../../i18n/t";

const locale = Astro.locals.locale;
const db = Astro.locals.db;
const today = getTodayISO();

const [allRestaurants, allPromotions] = await Promise.all([
  db.select().from(restaurants).where(eq(restaurants.active, 1)),
  db
    .select()
    .from(promotions)
    .where(
      dbAnd(lte(promotions.dateStart, today), gte(promotions.dateEnd, today)),
    ),
]);

const grouped = groupPromotionsByRestaurant(allPromotions);
const enriched = allRestaurants.map((r) => enrichRestaurant(r, grouped.get(r.id) ?? []));
---

<AppWrapper
  title={t("restaurants.pageTitle", locale)}
  description={t("restaurants.pageDesc", locale)}
  bodyClass="page-mangiare"
>
  <div class="mb-6 animate-fade-up flex items-start justify-between">
    <div>
      <h1
        class="font-family-display text-3xl font-medium tracking-tight text-primary"
      >
        {t("restaurants.pageTitle", locale)}
      </h1>
    </div>
    <button
      id="refresh-btn"
      type="button"
      aria-label={t("common.refresh", locale)}
      class="mt-1 flex h-9 w-9 items-center justify-center rounded-full border border-border-light bg-surface text-muted transition-all duration-300 hover:border-mangiare-muted hover:text-mangiare active:scale-90"
    >
      <svg
        class="h-[18px] w-[18px]"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="23 4 23 10 17 10"></polyline>
        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
      </svg>
    </button>
  </div>

  <script>
    import { initRefreshButton } from "../../utils/refresh";
    initRefreshButton();
  </script>

  <RestaurantsView client:load restaurants={enriched} locale={locale} />
  <ZipperScroll />
</AppWrapper>
