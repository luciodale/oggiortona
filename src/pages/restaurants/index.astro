---
import AppWrapper from "../../building-blocks/AppWrapper.astro";
import ZipperScroll from "../../components/shared/ZipperScroll.astro";
import { RestaurantsView } from "../../components/restaurants/RestaurantsView";
import { restaurants, promotions, pinnedRestaurants } from "../../db/schema";
import { eq, and as dbAnd, lte, gte } from "drizzle-orm";
import { getTodayISO } from "../../utils/date";
import { groupPromotionsByRestaurant, enrichRestaurant } from "../../utils/enrichRestaurant";
import { t } from "../../i18n/t";

const locale = Astro.locals.locale;
const db = Astro.locals.db;
const today = getTodayISO();

const [allRestaurants, allPromotions] = await Promise.all([
  db.select().from(restaurants).where(dbAnd(eq(restaurants.active, 1), eq(restaurants.deleted, 0))),
  db
    .select()
    .from(promotions)
    .where(
      dbAnd(lte(promotions.dateStart, today), gte(promotions.dateEnd, today)),
    ),
]);

const grouped = groupPromotionsByRestaurant(allPromotions);
const enriched = allRestaurants.map((r) => enrichRestaurant(r, grouped.get(r.id) ?? []));

const user = Astro.locals.user;
const initialPinnedIds = user
  ? (await db.select({ restaurantId: pinnedRestaurants.restaurantId }).from(pinnedRestaurants).where(eq(pinnedRestaurants.userId, user.id))).map((r) => r.restaurantId)
  : [];
---

<AppWrapper
  title={t("restaurants.pageTitle", locale)}
  description={t("restaurants.pageDesc", locale)}
  bodyClass="page-mangiare"
>
  <RestaurantsView client:load restaurants={enriched} locale={locale} isLoggedIn={!!user} initialPinnedIds={initialPinnedIds} />
  <ZipperScroll />
</AppWrapper>
