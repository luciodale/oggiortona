---
import AppWrapper from "../building-blocks/AppWrapper.astro";
import { SignInForm } from "../components/auth/SignInForm";
import { ArrowLeftIcon } from "../icons/ArrowLeftIcon";
import { t } from "../i18n/t";

const locale = Astro.locals.locale;
---

<AppWrapper
  title={t("auth.signIn", locale)}
  description={t("auth.signIn", locale)}
  bodyClass="page-mangiare"
>
  <div class="py-4">
    <a
      href="/"
      class="mb-4 inline-flex items-center gap-1 text-xs font-medium text-muted no-underline hover:text-primary"
    >
      <ArrowLeftIcon className="h-3.5 w-3.5" />
      {t("common.back", locale)}
    </a>

    <h1
      class="font-family-display text-2xl font-medium tracking-tight text-primary"
    >
      {t("auth.signIn", locale)}
    </h1>
    <p class="mb-6 mt-2 text-sm text-muted">
      {t("auth.signInDesc", locale)}
    </p>

    <SignInForm client:load locale={locale} />
  </div>
</AppWrapper>
