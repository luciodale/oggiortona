{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "oggi-a-ortona",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "main": "dist/_worker.js/index.js",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "oggi-a-ortona-db",
      "database_id": "local-dev-placeholder"
    }
  ]
}
